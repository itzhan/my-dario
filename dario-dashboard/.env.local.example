# Copy to .env.local and adjust.

# Where the running dario proxy lives. The browser never sees this — only
# the Next.js server talks to it.
DARIO_BASE_URL=http://localhost:3456

# Inbound key for dario, if you started the proxy with DARIO_API_KEY set
# (required whenever dario binds to a non-loopback --host). Injected by the
# BFF as `x-api-key`; never shipped to the browser. Leave blank for the
# default loopback proxy with no key.
DARIO_API_KEY=

# Path to dario's config file. The /config editor reads and writes this
# directly (same-machine deployment). Defaults to ~/.dario/config.json.
# DARIO_CONFIG_PATH=/Users/you/.dario/config.json

# Dashboard login. A single shared password gates the whole UI (it exposes
# your subscription's observability + config editing — do not run it open).
# Leave DASHBOARD_PASSWORD blank to disable the login gate (loopback-only).
DASHBOARD_PASSWORD=
# Any long random string; signs the session cookie.
AUTH_SECRET=change-me-to-a-long-random-string
