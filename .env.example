# Copy to .env and fill in, then: docker compose up -d --build

# Inbound key for the proxy. The dashboard reuses this value to authenticate,
# so it lives in one place. Generate one: openssl rand -hex 24
DARIO_API_KEY=

# Dashboard login password (required — the dashboard is on a network port).
DASHBOARD_PASSWORD=

# Signs the dashboard session cookie. Generate one: openssl rand -hex 32
AUTH_SECRET=

# Host port the dashboard is published on.
DASHBOARD_PORT=3088
